# ── Reasoning core ───────────────────────────────────────────────────
# Provider priority: Claude → Gemini → demo mode. Set EITHER key (or none —
# the app still runs in DEMO MODE with a deterministic mock so it never fails).

# Anthropic Claude (best quality, pay-as-you-go)
ANTHROPIC_API_KEY=
CASEWORKER_MODEL=claude-sonnet-4-6

# Google Gemini (free tier — great low-cost option). Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
CASEWORKER_GEMINI_MODEL=gemini-2.5-flash-lite

# ── Voice (ElevenLabs) ───────────────────────────────────────────────
# Optional. If absent, the "Listen" button is hidden gracefully.
ELEVENLABS_API_KEY=
# Default voice: "Rachel". Override with any ElevenLabs voice id.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
