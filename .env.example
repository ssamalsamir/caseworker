# ── Reasoning core (Anthropic Claude) ────────────────────────────────
# Without this key the app still runs in DEMO MODE with a high-quality
# deterministic mock so your demo never fails on stage.
ANTHROPIC_API_KEY=
# Optional: override the model. Defaults to a current Claude Sonnet.
CASEWORKER_MODEL=claude-sonnet-4-6

# ── Voice (ElevenLabs) ───────────────────────────────────────────────
# Optional. If absent, the "Listen" button is hidden gracefully.
ELEVENLABS_API_KEY=
# Default voice: "Rachel". Override with any ElevenLabs voice id.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
